# Copy to srv/{dev,prod}/container.env and fill in values.
# These are passed to the container at runtime via --env-file.

# LLM API key (required)
CONOS_OPENROUTER_API_KEY=sk-or-your-key-here

# SSH authorized keys (optional, for container SSH access)
# CONOS_SSH_AUTHORIZED_KEYS=ssh-ed25519 AAAA...

# Tailscale / Headscale (provisioned by: ansible-playbook playbooks/local/cos-provision.yml)
# TS_AUTH_KEY=<pre-auth key from Headscale, reusable recommended>
# CONOS_INFRA_TAILSCALE_HOSTNAME=cos
# CONOS_INFRA_TAILSCALE_LOGIN_SERVER=http://192.168.50.10:8080
