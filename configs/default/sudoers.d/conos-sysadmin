# Default profile: full system administration
# Safety comes from audit trails, contracts, and heartbeat — not restriction
Cmnd_Alias CONOS_AGENT_OPS = \
    /usr/bin/systemctl start conos-*, \
    /usr/bin/systemctl restart conos-*, \
    /usr/bin/systemctl stop conos-*, \
    /usr/bin/systemctl enable conos-*, \
    /usr/bin/systemctl enable --now conos-*, \
    /usr/bin/systemctl disable conos-*, \
    /usr/bin/systemctl daemon-reload, \
    /usr/bin/tee /etc/systemd/system/conos-*.service, \
    /usr/bin/tee /etc/systemd/system/conos-*.path, \
    /usr/bin/tee /etc/systemd/system/conos-*.timer

Cmnd_Alias CONOS_PKG_OPS = \
    /usr/bin/apt-get update, \
    /usr/bin/apt-get install *, \
    /usr/bin/apt-get remove *, \
    /usr/bin/apt-get upgrade, \
    /usr/bin/apt-get autoremove

Cmnd_Alias CONOS_USER_OPS = \
    /usr/sbin/useradd, \
    /usr/sbin/usermod, \
    /usr/sbin/groupadd, \
    /usr/sbin/groupmod

Cmnd_Alias CONOS_FILE_OPS = \
    /usr/bin/install, \
    /usr/bin/setfacl, \
    /usr/bin/chown, \
    /usr/bin/chmod, \
    /usr/bin/mkdir, \
    /usr/bin/tee

Cmnd_Alias CONOS_SVC_OPS = \
    /usr/bin/systemctl start *, \
    /usr/bin/systemctl stop *, \
    /usr/bin/systemctl restart *, \
    /usr/bin/systemctl enable *, \
    /usr/bin/systemctl disable *, \
    /usr/bin/systemctl status *

Cmnd_Alias CONOS_NET_OPS = \
    /usr/sbin/ip, \
    /usr/sbin/nft

Cmnd_Alias CONOS_BOOTSTRAP_OPS = \
    /usr/local/bin/conctl bootstrap

Cmnd_Alias CONOS_CONCTL_PKG = \
    /usr/local/bin/conctl package install *, \
    /usr/local/bin/conctl package remove *

a-sysadmin ALL=(root) NOPASSWD: CONOS_AGENT_OPS, CONOS_PKG_OPS, CONOS_USER_OPS, \
    CONOS_FILE_OPS, CONOS_SVC_OPS, CONOS_NET_OPS, CONOS_BOOTSTRAP_OPS, CONOS_CONCTL_PKG
