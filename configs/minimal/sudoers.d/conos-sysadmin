# Minimal profile: agent commissioning operations only
Cmnd_Alias CONOS_OPS = \
    /usr/bin/systemctl start conos-*, \
    /usr/bin/systemctl restart conos-*, \
    /usr/bin/systemctl enable conos-*, \
    /usr/bin/systemctl enable --now conos-*, \
    /usr/bin/systemctl daemon-reload, \
    /usr/sbin/useradd, \
    /usr/bin/install -d /srv/conos/agents/*, \
    /usr/bin/install -d -o a-* -g agents -m 700 /srv/conos/agents/*, \
    /usr/bin/setfacl -m u:a-*:* /srv/conos/agents/*, \
    /usr/bin/chown * /home/a-*, \
    /usr/bin/chmod 700 /home/a-*, \
    /usr/bin/tee /etc/systemd/system/conos-*.service, \
    /usr/bin/tee /etc/systemd/system/conos-*.path

a-sysadmin ALL=(root) NOPASSWD: CONOS_OPS
